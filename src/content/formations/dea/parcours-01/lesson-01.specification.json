    "items": [
      {
        "id": "F001",
        "question": "Qu'est-ce que l'anatomie ?",
        "answer": "Science décrivant la structure du corps humain."
      },
      {
        "id": "F002",
        "question": "Qu'étudie la physiologie ?",
        "answer": "Le fonctionnement normal des organes."
      },
      {
        "id": "F003",
        "question": "Quel est le plus petit niveau d'organisation ?",
        "answer": "La cellule."
      },
      {
        "id": "F004",
        "question": "Un organe est constitué de quoi ?",
        "answer": "De plusieurs tissus spécialisés."
      },
      {
        "id": "F005",
        "question": "Pourquoi l'anatomie est-elle indispensable à l'ambulancier ?",
        "answer": "Pour localiser une douleur, comprendre les lésions et transmettre un bilan précis."
      }
    ]
