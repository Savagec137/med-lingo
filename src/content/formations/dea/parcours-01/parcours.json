    },
    {
      "id": "dea-p01-l02",
      "order": 2,
      "title": "Cellules et tissus",
      "type": "lesson",
      "status": "draft",
      "bankFile": "parcours-01/lesson-02.json",
      "learningObjectives": [
        "définir une cellule ;",
        "identifier ses éléments essentiels au niveau DEA ;",
        "comprendre le rôle général de la cellule ;",
        "définir un tissu ;",
        "reconnaître les grandes catégories de tissus ;",
        "comprendre la relation cellule → tissu."
      ],
      "competencyIds": [
        "body.cell.definition",
        "body.cell.structure",
        "body.cell.function",
        "body.tissue.definition",
        "body.tissue.types",
        "body.organization.cell-to-tissue"
      ],
      "prerequisiteIds": ["dea-p01-l01"]
    },
    {
      "id": "dea-p01-l03",
      "order": 3,
      "title": "Les organes",
      "type": "lesson",
      "status": "published",
      "bankFile": "parcours-01/lesson-03.json",
      "learningObjectives": [
        "Définir un organe",
        "Comprendre sa composition",
        "Différencier organe et système",
        "Comprendre son rôle"
      ],
      "competencyIds": [
        "body.organ.definition",
        "body.organ.composition",
        "body.organ.function",
        "body.organ.location",
        "body.organization.tissue-to-organ"
      ],
      "prerequisiteIds": ["dea-p01-l02"]
    },
    {
      "id": "dea-p01-l04",
      "order": 4,
      "title": "Les systèmes du corps",
      "type": "lesson",
      "status": "draft",
      "bankFile": "parcours-01/lesson-04.json",
      "learningObjectives": [
        "définir un système ou appareil ;",
        "comprendre qu’un système regroupe plusieurs organes ;",
        "identifier les principaux systèmes ;",
        "relier chaque système à sa fonction générale."
      ],
      "competencyIds": [
        "body.system.definition",
        "body.system.cardiovascular",
