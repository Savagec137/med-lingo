      "title": "Pourquoi apprendre l'anatomie ?",
      "type": "lesson",
      "status": "published",
      "bankFile": "parcours-01/lesson-01.json",
      "learningObjectives": [
        "définir l’anatomie ;",
        "distinguer anatomie, physiologie et pathologie ;",
        "comprendre l’intérêt de l’anatomie pour le DEA ;",
        "comprendre l’organisation générale du corps humain."
      ],
      "competencyIds": [
        "anatomy.definition",
        "anatomy.dea-relevance",
        "physiology.definition",
        "pathology.definition",
        "body.organization"
      ],
